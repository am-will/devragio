{
  "name": "devragio",
  "version": "0.1.0",
  "description": "Count how many times you swear at — and thank — your coding agents",
  "keywords": [
    "cli",
    "claude",
    "codex",
    "coding-agents",
    "profanity",
    "politeness",
    "swears",
    "transcripts"
  ],
  "author": "am-will",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/am-will/devragio.git"
  },
  "homepage": "https://github.com/am-will/devragio#readme",
  "bugs": {
    "url": "https://github.com/am-will/devragio/issues"
  },
  "type": "module",
  "bin": {
    "devragio": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/cli.js",
    "build": "node build.js",
    "dev": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt --check src/"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.1",
    "esbuild": "^0.25.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  }
}
